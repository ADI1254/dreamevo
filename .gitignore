backend/SkyReels-V2/
TTS/

# --- Lean repo: heavy / optional folders (media often on Cloudflare R2 instead) ---
# See docs/LEAN_PUSH_TO_GITHUB.md
audio/
wix-integration/
frontend/assets/audio/
frontend/assets/videos/
frontend/SOUND EFFECTS/

# Large single files (GitHub max ~100MB per file; prefer CDN for video)
backend/static/*.mp4
backend/static/*.webm

# Cursor / local tooling (optional)
.cursor/

# Logs & temp
*.log
.cache/
